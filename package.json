{
  "name": "@virtuoso.dev/monorepo",
  "private": true,
  "scripts": {
    "ci": "pnpm ci-setup && pnpm build && pnpm typecheck && pnpm lint && pnpm test && pnpm e2e",
    "ci-setup": "pnpm --filter \"*\" run ci-setup",
    "typecheck": "pnpm --filter \"*\" run typecheck",
    "lint": "pnpm --filter \"*\" run lint",
    "test": "pnpm --filter \"*\" run test",
    "e2e": "pnpm --filter \"*\" run e2e",
    "build": "pnpm --filter \"*\" run build",
    "build-virtuoso.dev": "pnpm --filter @virtuoso.dev/virtuoso.dev run build",
    "release": "pnpm build && pnpm publish -r",
    "changeset-add": "pnpm changeset add",
    "dev:docs": "pnpm --filter @virtuoso.dev/virtuoso.dev run dev"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8"
  },
  "packageManager": "pnpm@10.24.0",
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=10.24",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": ">=22.0.0",
      "onFail": "error"
    }
  }
}
