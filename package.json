{
  "name": "@virtuoso.dev/monorepo",
  "private": true,
  "scripts": {
    "ci": "pnpm ci-setup && pnpm build && pnpm typecheck && pnpm lint && pnpm lint:md && pnpm test && pnpm e2e",
    "ci-setup": "pnpm run --if-present --parallel --no-bail ci-setup",
    "typecheck": "pnpm run --if-present --parallel typecheck",
    "lint": "pnpm run --if-present --parallel --no-bail lint",
    "lint:md": "markdownlint '**/*.md' --ignore-path .markdownlintignore",
    "lint:md:fix": "markdownlint '**/*.md' --ignore-path .markdownlintignore --fix",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "test": "pnpm run --if-present --parallel --no-bail test",
    "e2e": "pnpm run --if-present --parallel --no-bail e2e",
    "build": "pnpm --if-present --recursive run build",
    "release": "pnpm build && pnpm exec changeset publish",
    "changeset-add": "pnpm changeset add",
    "dev:docs": "pnpm --filter @virtuoso.dev/virtuoso.dev run dev",
    "build-virtuoso.dev": "pnpm --filter @virtuoso.dev/virtuoso.dev run build",
    "prepare": "lefthook install",
    "knip": "knip"
  },
  "devDependencies": {
    "@changesets/changelog-github": "^0.6.0",
    "@changesets/cli": "^2.30.0",
    "@types/node": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260330.1",
    "knip": "^6.1.0",
    "lefthook": "^2.1.4",
    "markdownlint-cli": "^0.48.0",
    "oxfmt": "^0.42.0",
    "oxlint": "^1.57.0",
    "oxlint-tsgolint": "^0.18.1",
    "typescript": "catalog:"
  },
  "devEngines": {
    "packageManager": {
      "name": "pnpm",
      "version": ">=10.24",
      "onFail": "error"
    },
    "runtime": {
      "name": "node",
      "version": ">=22.0.0",
      "onFail": "error"
    }
  },
  "packageManager": "pnpm@10.24.0",
  "pnpm": {
    "peerDependencyRules": {
      "allowedVersions": {
        "react-inspector>react": "19"
      }
    }
  }
}
