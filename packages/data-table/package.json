{
  "name": "@virtuoso.dev/data-table",
  "version": "0.1.3",
  "private": false,
  "description": "Virtualized React data table component with column and row virtualization.",
  "keywords": [
    "columns",
    "data table",
    "endless scrolling",
    "grid",
    "infinite",
    "react",
    "scrolling",
    "table",
    "virtual",
    "virtualized"
  ],
  "homepage": "https://virtuoso.dev/data-table/",
  "bugs": {
    "email": "support@virtuoso.dev"
  },
  "license": "MIT",
  "author": "The Virtuoso team <support@virtuoso.dev>",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/petyosi/react-virtuoso.git",
    "directory": "packages/data-table"
  },
  "files": [
    "CHANGELOG.md",
    "dist"
  ],
  "type": "module",
  "sideEffects": [
    "*.css"
  ],
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    },
    "./column-reorder": {
      "import": {
        "types": "./dist/column-reorder.d.ts",
        "default": "./dist/column-reorder.js"
      }
    },
    "./column-resize": {
      "import": {
        "types": "./dist/column-resize.d.ts",
        "default": "./dist/column-resize.js"
      }
    },
    "./column-visibility": {
      "import": {
        "types": "./dist/column-visibility.d.ts",
        "default": "./dist/column-visibility.js"
      }
    },
    "./state-persistence": {
      "import": {
        "types": "./dist/state-persistence.d.ts",
        "default": "./dist/state-persistence.js"
      }
    },
    "./styles.css": "./dist/styles.css"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc && vite build",
    "lint": "oxlint --type-aware --type-check",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "dev": "LADLE=true ladle serve",
    "dev:build": "LADLE=true ladle build",
    "dev:preview": "LADLE=true ladle preview",
    "test": "vitest run --browser.headless",
    "test:all": "VITEST_SLOW=true vitest run --browser.headless",
    "test:slow": "VITEST_SLOW=true vitest run --browser.headless --tags-filter=slow",
    "typecheck": "tsgo -b --noEmit",
    "check": "pnpm format:check && pnpm lint && pnpm typecheck",
    "knip": "cd ../.. && knip --workspace packages/data-table"
  },
  "dependencies": {
    "@virtuoso.dev/reactive-engine-core": "workspace:*",
    "@virtuoso.dev/reactive-engine-react": "workspace:*",
    "tiny-invariant": "catalog:"
  },
  "devDependencies": {
    "@ladle/react": "catalog:",
    "@ngneat/falso": "^8.0.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "catalog:",
    "@types/react": "catalog:",
    "@types/react-dom": "catalog:",
    "@typescript/native-preview": "7.0.0-dev.20260308.1",
    "@vitejs/plugin-react": "catalog:",
    "@vitest/browser-playwright": "catalog:",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "jsdom": "catalog:",
    "knip": "catalog:",
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "oxlint-tsgolint": "catalog:",
    "random-avatar-generator": "^2.0.0",
    "react": "catalog:",
    "react-dom": "catalog:",
    "resize-observer-polyfill": "^1.5.1",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vite-plugin-dts": "catalog:",
    "vitest": "catalog:",
    "vitest-browser-react": "^2.0.2"
  },
  "peerDependencies": {
    "react": ">= 16 || >= 17 || >= 18 || >= 19",
    "react-dom": ">= 16 || >= 17 || >= 18 || >= 19"
  }
}
