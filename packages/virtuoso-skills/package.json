{
  "name": "@virtuoso.dev/virtuoso-skills",
  "version": "0.1.1",
  "private": true,
  "description": "Agent skill distribution for Virtuoso React virtualization packages.",
  "type": "module",
  "scripts": {
    "build": "tsx scripts/build-skills.ts",
    "sync-version": "tsx scripts/sync-plugin-version.ts",
    "version": "pnpm sync-version",
    "validate": "pnpm validate:claude && pnpm validate:codex",
    "validate:claude": "claude plugin validate . --strict",
    "validate:codex": "tsx scripts/validate-codex-plugin.ts",
    "check": "pnpm validate"
  },
  "devDependencies": {
    "@types/node": "catalog:",
    "tsx": "4.20.6",
    "typescript": "catalog:"
  }
}
