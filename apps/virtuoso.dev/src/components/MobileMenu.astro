---
import { MobileMenu as MobileMenuComponent } from './MobileMenu'

const currentPath = Astro.url.pathname

function isActive(path: string): boolean {
  if (path === '/') {
    return currentPath === '/'
  }
  return currentPath.startsWith(path)
}

const navLinks = [
  { href: '/react-virtuoso/', isActive: isActive('/react-virtuoso/'), label: 'React Virtuoso' },
  { href: '/message-list/', isActive: isActive('/message-list/'), label: 'Message List' },
  { badge: 'New', href: '/data-table/', isActive: isActive('/data-table/'), label: 'Data Table' },
  { href: '/masonry/', isActive: isActive('/masonry/'), label: 'Virtuoso Masonry' },
  { href: '/pricing/', isActive: isActive('/pricing/'), label: 'Pricing' },
  { href: '/skills/', isActive: isActive('/skills/'), label: 'Agent Skills' },
]
---

<MobileMenuComponent client:load navLinks={navLinks} />
